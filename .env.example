# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/assistant.db

# ─── LLM Provider ─────────────────────────────────────────────────────────
# Options: "ollama" | "anthropic" | "openai"
# Only Anthropic (Claude) has been tested with the full agentic tool-calling loop.
# OpenAI and Ollama work for basic chat and structured output.
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2

# Ollama (free, local, offline — no API key needed)
# Install: https://ollama.com → run `ollama pull llama3.2`
OLLAMA_BASE_URL=http://localhost:11434

# Anthropic (Claude) — recommended for full agentic features
# Models: claude-haiku-4-5-20251001 (fast), claude-sonnet-4-20250514 (capable)
# Get key: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI — basic chat + structured output (tool calling not yet implemented)
# Models: gpt-4o-mini, gpt-4o
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── App Settings ─────────────────────────────────────────────────────────
DEBUG=false
TIMEZONE=Asia/Kolkata

# ─── Schedule Defaults ────────────────────────────────────────────────────
# These control the auto-scheduler's time boundaries
DEFAULT_WAKE_TIME=07:00
DEFAULT_SLEEP_TIME=23:00
DEFAULT_WORK_START=09:00
DEFAULT_WORK_END=17:00
DEFAULT_TASK_DURATION_MIN=30
REMINDER_LEAD_TIME_MIN=10

# ─── Google Calendar Integration (optional) ───────────────────────────────
# Setup guide: see README.md → Google Calendar Integration
# 1. Create OAuth credentials at https://console.cloud.google.com/
# 2. Enable "Google Calendar API"
# 3. Set redirect URI to the callback URL below
# 4. Add your email as a test user in OAuth consent screen
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/integrations/google/callback
GOOGLE_CALENDAR_ID=primary

# ─── Telegram Bot Integration (optional) ──────────────────────────────────
# Setup guide: see README.md → Telegram Bot Integration
# 1. Message @BotFather on Telegram → /newbot → copy token
# 2. Start the bot, send /start — chat ID is auto-captured
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
# Optional: set manually if you want proactive notifications without messaging first
# Find your chat ID via @userinfobot on Telegram
TELEGRAM_CHAT_ID=
