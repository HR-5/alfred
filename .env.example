# Database
DATABASE_URL=sqlite+aiosqlite:///./data/assistant.db

# LLM Provider: "ollama" | "anthropic" | "openai"
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Anthropic (optional)
ANTHROPIC_API_KEY=

# OpenAI (optional)
OPENAI_API_KEY=

# App
DEBUG=true
TIMEZONE=Asia/Kolkata
